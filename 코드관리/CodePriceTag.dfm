  object FastReport: TfrxReport
    Version = '6.9.12'
    DotMatrixReport = False
    EngineOptions.DoublePass = True
    EngineOptions.UseFileCache = True
    IniFile = '\Software\Fast Reports'
    PreviewOptions.Buttons = [pbPrint, pbLoad, pbSave, pbExport, pbZoom, pbFind, pbOutline, pbPageSetup, pbTools, pbEdit, pbNavigator, pbExportQuick, pbCopy, pbSelection]
    PreviewOptions.Zoom = 1.000000000000000000
    PrintOptions.Printer = 'Default'
    PrintOptions.PrintOnSheet = 0
    ReportOptions.CreateDate = 43732.737375428200000000
    ReportOptions.LastChange = 43732.737375428200000000
    ScriptLanguage = 'PascalScript'
    ScriptText.Strings = (
      'function  GetBarcode(aCode: string): string;'
      '  function UpcE2UpcA(aCode: string): string;'
      '  begin'
      '    if Length(aCode) = 7 then'
      '      aCode := Copy(aCode, 1, 6)'
      '    else if Length(aCode) = 8 then'
      '      aCode := Copy(aCode, 2, 6);'
      '    case aCode[6] of'
      '      '#39'0'#39','#39'1'#39','#39'2'#39':'
      
        '        Result := '#39'0'#39' + Copy(aCode, 1, 2) + aCode[6] + '#39'0000'#39' + ' +
        'Copy(aCode, 3, 3) + '#39'0'#39';'
      '      '#39'3'#39':'
      
        '        Result := '#39'0'#39' + Copy(aCode, 1, 3) + '#39'00000'#39' + Copy(aCode' +
        ', 4, 2) + '#39'0'#39';'
      '      '#39'4'#39':'
      
        '        Result := '#39'0'#39' + Copy(aCode, 1, 4) + '#39'00000'#39' + aCode[5] +' +
        ' '#39'0'#39';'
      '      else'
      
        '        Result := '#39'0'#39' + Copy(aCode, 1, 5) + '#39'0000'#39' + aCode[6] + ' +
        #39'0'#39';'
      '    end;'
      '  end;  '
      ''
      '  function GetOnlyNumber(const aValue: string): string;'
      '  var'
      '    vIndex: Integer;'
      '  begin'
      '    Result := '#39#39';'
      '    for vIndex := Length(aValue) downto 1 do'
      
        '      if aValue[vIndex] in ['#39'0'#39','#39'1'#39','#39'2'#39','#39'3'#39','#39'4'#39','#39'5'#39','#39'6'#39','#39'7'#39','#39'8'#39',' +
        #39'9'#39'] then'
      '        Insert(aValue[vIndex], Result, 1);'
      '  end;       '
      'var        '
      '  vOdd, vEven: Integer;'
      '  vUPCE: string;'
      'begin'
      '  // '#48148#53076#46300#50640' '#47928#51088#44032' '#54252#54632#46104#50612' '#51080#45716#51648' '#54869#51064
      '  aCode := GetOnlyNumber(aCode);'
      ''
      '  // UPC-E '#53076#46300#47732' UPC-A'#47196' '#48148#45012#49436' '#52404#53356#46356#51648#53944#47484' '#44396#54620#45796
      
        '  if (Length(aCode) = 6) or (Length(aCode) = 7) or ((Length(aCod' +
        'e) = 8) and (aCode[1] = '#39'0'#39')) then'
      '  begin'
      '    vUPCE := aCode;'
      '    aCode := UpcE2UpcA(aCode);'
      '  end'
      '  else'
      '    vUPCE := '#39#39';'
      '  // '#48148#53076#46300' '#52404#53356#46356#51648#53944' '#44228#49328
      '  case Length(aCode) of'
      '     8 : begin // EAN-8'
      
        '           vOdd   := StrToInt(aCode[1])+StrToInt(aCode[3])+StrTo' +
        'Int(aCode[5])+StrToInt(aCode[7]);'
      
        '           vEven  := StrToInt(aCode[2])+StrToInt(aCode[4])+StrTo' +
        'Int(aCode[6]);'
      
        '           Result := Copy(aCode,1,7) + IntToStr((10 - ((vOdd*3 +' +
        ' vEven) mod 10)) mod 10);'
      '         end;'
      '    12 : begin // UPC-A'
      
        '           vOdd   := StrToInt(aCode[1])+StrToInt(aCode[3])+StrTo' +
        'Int(aCode[5])+StrToInt(aCode[7])+StrToInt(aCode[ 9])+StrToInt(aC' +
        'ode[11]);'
      
        '           vEven  := StrToInt(aCode[2])+StrToInt(aCode[4])+StrTo' +
        'Int(aCode[6])+StrToInt(aCode[8])+StrToInt(aCode[10]);'
      '           if vUPCE = '#39#39' then'
      
        '             Result := Copy(aCode,1,11) + IntToStr((10 - ((vOdd*' +
        '3 + vEven) mod 10)) mod 10)'
      '           else'
      
        '             Result := Copy(vUPCE,1,Length(vUPCE)-1) + IntToStr(' +
        '(10 - ((vOdd*3 + vEven) mod 10)) mod 10);'
      '         end;'
      '    13 : begin // EAN-13'
      
        '           vOdd   := StrToInt(aCode[1])+StrToInt(aCode[3])+StrTo' +
        'Int(aCode[5])+StrToInt(aCode[7])+StrToInt(aCode[ 9])+StrToInt(aC' +
        'ode[11]);'
      
        '           vEven  := StrToInt(aCode[2])+StrToInt(aCode[4])+StrTo' +
        'Int(aCode[6])+StrToInt(aCode[8])+StrToInt(aCode[10])+StrToInt(aC' +
        'ode[12]);'
      
        '           Result := Copy(aCode,1,12) + IntToStr((10 - ((vOdd + ' +
        'vEven*3) mod 10)) mod 10);'
      '         end;'
      '    14 : begin // EAN-14, ITF-14 (Box)'
      
        '           vOdd   := StrToInt(aCode[1])+StrToInt(aCode[3])+StrTo' +
        'Int(aCode[5])+StrToInt(aCode[7])+StrToInt(aCode[ 9])+StrToInt(aC' +
        'ode[11])+StrToInt(aCode[13]);'
      
        '           vEven  := StrToInt(aCode[2])+StrToInt(aCode[4])+StrTo' +
        'Int(aCode[6])+StrToInt(aCode[8])+StrToInt(aCode[10])+StrToInt(aC' +
        'ode[12]);'
      
        '           Result := Copy(aCode,1,13) + IntToStr((10 - ((vOdd*3 ' +
        '+ vEven) mod 10)) mod 10);'
      '         end;'
      '    else       // '#44592#53440' (UPC-E'#45716' '#52404#53356#46356#51648#53944' '#44228#49328#51060' '#46104#51648' '#50506#45716#45796')'
      '         Result := aCode;'
      '  end;'
      'end;'
      '  '
      'procedure DesignImageOnBeforePrint(Sender: TfrxComponent);'
      'begin'
      '  if (Sender is TfrxPictureView) and'
      
        '     (TfrxPictureView(Sender).Visible) and (TfrxPictureView(Send' +
        'er).Printable) and'
      '     (TfrxPictureView(Sender).TagStr <> '#39#39') then'
      '    try'
      
        '      TfrxPictureView(Sender).LoadFromFile(TfrxPictureView(Sende' +
        'r).TagStr);'
      '    except'
      '    end;              '
      'end;'
      ''
      'procedure DesignBarcodeOnAfterData(Sender: TfrxComponent);'
      'begin'
      
        '  if (GetBarCode(TfrxBarCodeView(Sender).Text) <> TfrxBarCodeVie' +
        'w(Sender).Text) then'
      '    TfrxBarCodeView(Sender).BarType := bcCode128C        '
      '  else                  '
      '    case Length(TfrxBarCodeView(Sender).Text) of'
      
        '      8  : TfrxBarCodeView(Sender).BarType := bcCodeEAN8;       ' +
        '                                              '
      '      13 : TfrxBarCodeView(Sender).BarType := bcCodeEAN13;  '
      '      7  : TfrxBarCodeView(Sender).BarType := bcCodeUPC_E0;  '
      '      12 : TfrxBarCodeView(Sender).BarType := bcCodeUPC_A;  '
      '      14 : TfrxBarCodeView(Sender).BarType := bcCode128C;  '
      
        '      else TfrxBarCodeView(Sender).BarType := bcCode128A;       ' +
        '         '
      '    end;'
      ''
      '  if TfrxBarCodeView(Sender).Font.Size = 1 then'
      
        '     TfrxBarCodeView(Sender).ShowText := false;                 ' +
        '                                        '
      'end;'
      ''
      'begin'
      ''
      'end.')
