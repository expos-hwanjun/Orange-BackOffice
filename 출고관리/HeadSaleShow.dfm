      'procedure DesignImageOnBeforePrint(Sender: TfrxComponent);'
      'begin'
      '  if (Sender is TfrxPictureView) and'
      
        '     (TfrxPictureView(Sender).Visible) and (TfrxPictureView(Send' +
        'er).Printable) and'
      '     (TfrxPictureView(Sender).TagStr <> '#39#39') then'
      '    try'
      
        '      TfrxPictureView(Sender).LoadFromFile(TfrxPictureView(Sende' +
        'r).TagStr);'
      '    except'
      '    end;              '
      'end;'
      ''
      'procedure DesignBarcodeOnAfterData(Sender: TfrxComponent);'
      'begin'
      '  case Length(TfrxBarCodeView(Sender).Text) of'
      
        '    8  : TfrxBarCodeView(Sender).BarType := bcCodeEAN8;         ' +
        '                                            '
      '    13 : TfrxBarCodeView(Sender).BarType := bcCodeEAN13;  '
      '    7  : TfrxBarCodeView(Sender).BarType := bcCodeUPC_E0;  '
      '    12 : TfrxBarCodeView(Sender).BarType := bcCodeUPC_A;  '
      
        '    else TfrxBarCodeView(Sender).BarType := bcCode39;           ' +
        '     '
      '  end;  '
      'end;'
      ''
      'begin'
      ''
      'end.')
