  object Script: TUniScript
    SQL.Strings = (
      
        'if exists (select * from INFORMATION_SCHEMA.COLUMNS where TABLE_' +
        'NAME = '#39'MS_TRD'#39' and COLUMN_NAME = '#39'CD_STORE_LINK'#39') '
      ' alter table dbo.MS_TRD drop column '#39'CD_STORE_LINK'#39' '
      'GO'
      
        'if exists (select * from INFORMATION_SCHEMA.COLUMNS where TABLE_' +
        'NAME = '#39'MS_TRD_ETC'#39' and COLUMN_NAME = '#39'APP_ID'#39') '
      ' alter table dbo.MS_TRD_ETC drop column '#39'APP_ID'#39' '
      'GO'
      
        'if exists (select * from INFORMATION_SCHEMA.COLUMNS where TABLE_' +
        'NAME = '#39'MS_TRD_ETC'#39' and COLUMN_NAME = '#39'APP_PWD'#39') '
      ' alter table dbo.MS_TRD_ETC drop column '#39'APP_PWD'#39' '
      'GO'
      
        'if exists (select * from INFORMATION_SCHEMA.COLUMNS where TABLE_' +
        'NAME = '#39'MS_TRD_HIST'#39' and COLUMN_NAME = '#39'NM_DEPOSIT'#39') '
      ' alter table dbo.MS_TRD_HIST drop column '#39'NM_DEPOSIT'#39' '
      'GO'
      
        'if exists (select * from INFORMATION_SCHEMA.COLUMNS where TABLE_' +
        'NAME = '#39'MS_TRD_HIST'#39' and COLUMN_NAME = '#39'NM_DEPOSIT1'#39') '
      ' alter table dbo.MS_TRD_HIST drop column '#39'NM_DEPOSIT1'#39' '
      'GO'
      
        'if exists (select * from INFORMATION_SCHEMA.COLUMNS where TABLE_' +
        'NAME = '#39'MS_TRD_HIST'#39' and COLUMN_NAME = '#39'NM_DEPOSIT2'#39') '
      ' alter table dbo.MS_TRD_HIST drop column '#39'NM_DEPOSIT2'#39' '
      'GO'
      
        'if exists (select * from INFORMATION_SCHEMA.COLUMNS where TABLE_' +
        'NAME = '#39'MS_MEMBER'#39' and COLUMN_NAME = '#39'PRG_CHG'#39') '#39
      ' alter table dbo.MS_MEMBER drop column '#39'PRG_CHG'#39' '
      'GO'
      
        'if exists (select * from INFORMATION_SCHEMA.COLUMNS where TABLE_' +
        'NAME = '#39'MS_MEMBER_HIST'#39' and COLUMN_NAME = '#39'PRG_CHG'#39') '
      ' alter table dbo.MS_MEMBER_HIST drop column '#39'PRG_CHG'#39' '
      'GO'
      
        'if exists (select * from INFORMATION_SCHEMA.COLUMNS where TABLE_' +
        'NAME = '#39'MS_MEMBER_ETC'#39' and COLUMN_NAME = '#39'APP_ID'#39') '
      ' alter table dbo.MS_MEMBER_ETC drop column '#39'APP_ID'#39' '
      'GO'
      
        'if exists (select * from INFORMATION_SCHEMA.COLUMNS where TABLE_' +
        'NAME = '#39'MS_MEMBER_ETC'#39' and COLUMN_NAME = '#39'APP_PWD'#39') '
      ' alter table dbo.MS_MEMBER_ETC drop column '#39'APP_PWD'#39' '
      'GO'
      
        'if exists (select * from INFORMATION_SCHEMA.COLUMNS where TABLE_' +
        'NAME = '#39'MS_GOODS'#39' and COLUMN_NAME = '#39'YN_WEBORDER'#39') '
      ' alter table dbo.MS_GOODS drop column '#39'YN_WEBORDER'#39' '
      'GO'
      
        'if exists (select * from INFORMATION_SCHEMA.COLUMNS where TABLE_' +
        'NAME = '#39'SL_TAX'#39#39' and COLUMN_NAME = '#39'NO_TEL'#39') '
      ' alter table dbo.SL_TAX drop column '#39'NO_TEL'#39' '
      'GO')
    Connection = Connection
    Left = 568
    Top = 56
  end
