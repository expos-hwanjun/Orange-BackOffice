function TSystemSetupForm.SearchMenu(aExistMenu, aType:String): String;
begin
  Result := EmptyStr;
  with THelpForm.Create(Self) do
    try
      Caption                    := '메뉴 조회';
      GridTableViewCode.Caption  := '메뉴 코드';
      GridTableViewCode.Width    := 100;
      GridTableViewName1.Caption := '메뉴 이름';
      GridTableViewName1.Width   := 320;

      SQLText    := 'select CD_MENU, '
                   +'       NM_MENU '
                   +'  from MS_MENU '
                   +' where CD_HEAD  =:P0 '
                   +'   and CD_STORE =:P1 '
                   +'  and  DS_MENU_TYPE = ''N'' '
                   +Ifthen(aType ='0',' and PR_SALE = 0','')
                   +'  and  (CD_MENU =:P2 or NM_MENU like ConCat(''%'',:P2,''%'')) '
                   +'  and  YN_USE = ''Y'' '
                   +'  and  CD_MENU <> '''+aExistMenu+''' '
                   +'order by CD_MENU';
      IsAutoSearch := true; // 폼 띄우면서 자동 검색
      if ShowModal = mrOK then
      begin
        Result    := Code;
        if aType = '1' then
          CheckMenuButtonEdit.Hint := Names[0];
        isChanged := true;
      end;
    finally
      Free;
    end;
end;

