procedure TSystemSetupForm.EditPropertiesChange(Sender: TObject);
var
  vIndex, vIndex2: Integer;
  vTemp: string;
begin
  if isLoading then
    Exit;

//  inherited;

  //Option CheckBox일때
  if (Sender is TcxCheckBox) and (Length(GetOnlyNumber((Sender as TcxCheckBox).Name)) = 3) and (LeftStr((Sender as TcxCheckBox).Name, 6)= 'Option') then
  begin
    Option[StrToInt(GetOnlyNumber((Sender as TcxCheckBox).Name))] := IfThen(TcxCheckBox(Sender).Checked, '1', '0')[1];
  end;

  //Option ComboBox일때
  if (Sender is TcxComboBox) and (Length(GetOnlyNumber((Sender as TcxComboBox).Name)) = 3) and (LeftStr((Sender as TcxComboBox).Name, 6)= 'Option') then
  begin
    Option[StrToInt(GetOnlyNumber((Sender as TcxComboBox).Name))] := IntToStr(TcxComboBox(Sender).ItemIndex)[1];
  end;

  // 테이블명 기능을 사용합니다.
  if Sender = Option025CheckBox then
  begin
    Option024RadioGroup.Properties.Items[0].Caption := Ifthen(Option025CheckBox.Checked, '테이블명 표시', '테이블 번호 표시');
    EditPropertiesChange(Option024RadioGroup);
  end
  //테이블명 or 메뉴명 표시
  else if Sender = Option024RadioGroup then
  begin
    TableButton.Caption := '';
    TableButton.Amount.Caption := '15,000원';
    if Option025CheckBox.Checked then
    begin
      TableButton.Number.ShowNumber := False;
      //주문메뉴표 시 안할때는 테이블명을 표시
      if Option024RadioGroup.ItemIndex = 0 then
      begin
        TableButton.Menu.Name := '';
        TableButton.Menu.Qty  := '';
        TableButton.Caption := 'VIP실'+#13#13;
        TableButton.Number.NumberString := '';
      end
      else
      begin
        TableButton.Menu.Name := '짜장면'#13'탕수육';
        TableButton.Menu.Qty  := '3'#13'2';
        TableButton.Number.NumberString := 'VIP실';
      end;
    end
    //테이블명 기능을 사용하지 않을때
    else
    begin
      if Option024RadioGroup.ItemIndex = 0 then
      begin
        TableButton.Amount.Caption := '5번';
        TableButton.Menu.Name := '';
        TableButton.Menu.Qty  := '';
        TableButton.Number.NumberString := '';
      end
      else
      begin
        TableButton.Menu.Name := '짜장면'#13'탕수육';
        TableButton.Menu.Qty  := '3'#13'2';
        TableButton.Number.NumberString := 'VIP실';
      end;
    end;

    Option174CheckBox.Enabled := (Option024RadioGroup.ItemIndex = 0) and (Option025CheckBox.Checked);
    Option174CheckBox.Checked := not ((Option024RadioGroup.ItemIndex = 0) and (Option025CheckBox.Checked));
    TableButton.Refresh;
  end
  else if (Sender is TcxComboBox) and (LeftStr((Sender as TcxComboBox).Name,3) = 'Option') and (RightStr((Sender as TcxComboBox).Name,7) = 'ComboBox') and ((Sender as TcxComboBox).Properties.Items[0] = '출력안함') then
  begin
    if (Sender as TcxComboBox).Text = '출력안함' then
      TPanel(FindComponent(LeftStr((Sender as TcxComboBox).Name,9)+'Panel')).Font.Style := [fsStrikeOut]
    else
      TPanel(FindComponent(LeftStr((Sender as TcxComboBox).Name,9)+'Panel')).Font.Style := [];
  end
  //주문 시 고객정보 입력합니다
  else if Sender = Option014CheckBox then
  begin
    Option014RadioGroup.Enabled   := Option014CheckBox.Checked;
    if not Option014CheckBox.Checked then
      Option037CheckBox.Checked   := Option014CheckBox.Checked;
    if not Option014CheckBox.Checked then
      Option037CheckBox.Enabled := false;
  end
  //메뉴별로 출력시에만 메뉴그룹 출력을 사용할 수 있게 한다
  else if Sender = Option009RadioGroup then
  begin
    Option079CheckBox.Enabled := Option009RadioGroup.ItemIndex = 1;
    if Option009RadioGroup.ItemIndex = 0 then
      Option079CheckBox.Checked := false;

    if (Option009RadioGroup.ItemIndex = 1) and not Option079CheckBox.Checked and not Option241CheckBox.Checked then
      Option374CheckBox.Enabled := true
    else
    begin
      Option374CheckBox.Enabled := false;
      Option374CheckBox.Checked := false;
    end;
  end
  else if Sender = Option079CheckBox then
  begin
    if (Option009RadioGroup.ItemIndex = 1) and not Option079CheckBox.Checked and not Option241CheckBox.Checked then
      Option374CheckBox.Enabled := true
    else
    begin
      Option374CheckBox.Enabled := false;
      Option374CheckBox.Checked := false;
    end;
  end
  //고객주문서 하단문구
  else if Sender = Option003CheckBox then
  begin
    if not Option003CheckBox.Checked then
    begin
      CustomerBottomMemo.Clear;
      CustomerBottomMemo.Enabled := false;
    end
    else
      CustomerBottomMemo.Enabled := true;
  end
  //배달주문서 하단문구
  else if Sender = Option228CheckBox then
  begin
    if not Option228CheckBox.Checked then
    begin
      DeliveryBottomMemo.Clear;
      DeliveryBottomMemo.Enabled := false;
    end
    else
      DeliveryBottomMemo.Enabled := true;
  end
  //봉사료관련
  else if (Sender = Option020CheckBox) or (Sender = Option160CheckBox) or (Sender = Option289CheckBox) then
  begin
    Option160CheckBox.Enabled    := Option020CheckBox.Checked;
    Option289CheckBox.Enabled    := Option020CheckBox.Checked;
    if Option160CheckBox.Checked then
    begin
      Option289CheckBox.Enabled := False;
      Option289CheckBox.Checked := False;
    end
    else
    begin
      Option289CheckBox.Enabled := Option020CheckBox.Checked;
      if not Option020CheckBox.Checked then Option289CheckBox.Checked := False;
