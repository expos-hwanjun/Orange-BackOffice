procedure TSystemSetupForm.StandbyImageGridTableViewCellDblClick(
  Sender: TcxCustomGridTableView; ACellViewInfo: TcxGridTableDataCellViewInfo;
  AButton: TMouseButton; AShift: TShiftState; var AHandled: Boolean);
var vImageURL, vImageFileName, vFolder :String;
    vMemStream :TMemoryStream;
    vHttpClient: THttpClient;
begin
  inherited;
  StandbyImagePanel.Top := Self.Height div 2 - StandbyImagePanel.Height div 2;
  StandbyImagePanel.Left := Self.Width div 2 - StandbyImagePanel.Width div 2;
  StandbyImagePanel.Visible := true;

  vImageFileName := StandbyImageGridTableView.DataController.Values[StandbyImageGridTableView.DataController.GetFocusedRecordIndex, StandbyImageGridTableViewFileName.Index];
  vImageURL      := StandbyImageGridTableView.DataController.Values[StandbyImageGridTableView.DataController.GetFocusedRecordIndex, StandbyImageGridTableViewImageURL.Index];

  vFolder := Format('%s\Image\LetsOrder\%s\%s\',[Folder,HeadStoreCode,StoreCode]);
  if not DirectoryExists(vFolder) then
    ForceDirectories(vFolder);

  if vImageURL <> '' then
  begin
    vMemStream :=TMemoryStream.Create;
    try
      vHttpClient:=THttpClient.Create;
      try
        vHttpClient.Get(vImageURL, vMemStream);
      finally
        FreeAndNil(vHttpClient);
      end;
      vMemStream.SaveToFile(vFolder+vImageFileName);
      try
        StandbyViewImage.Picture.LoadFromFile(vFolder+vImageFileName);
      except
        ErrBox('이미지화일 형식이 올바르지 않습니다');
      end;
    finally
      FreeAndNil(vMemStream);
    end;
  end;
end;

