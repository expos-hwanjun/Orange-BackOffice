procedure TSystemSetupForm.RustDeskPaintBoxPaint(Sender: TObject);
var
  Scale: Double;
begin
  RustDeskPaintBox.Canvas.Brush.Color := clWhite;
  RustDeskPaintBox.Canvas.FillRect(Rect(0, 0, RustDeskPaintBox.Width, RustDeskPaintBox.Height));
  if ((RustDeskBitmap.Width > 0) and (RustDeskBitmap.Height > 0)) then
  begin
    if (RustDeskPaintBox.Width < RustDeskPaintBox.Height) then
    begin
      Scale := RustDeskPaintBox.Width / RustDeskBitmap.Width;
    end else
    begin
      Scale := RustDeskPaintBox.Height / RustDeskBitmap.Height;
    end;
    RustDeskPaintBox.Canvas.StretchDraw(Rect(0, 0, Trunc(Scale * RustDeskBitmap.Width), Trunc(Scale * RustDeskBitmap.Height)), RustDeskBitmap);
  end;
end;

