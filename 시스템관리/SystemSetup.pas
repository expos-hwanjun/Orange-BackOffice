  vWaitImage := Format('{"url":"%s","head":"%s","store":"%s","FILE":[%s]}',[vDownURL, HeadStoreCode, StoreCode, LeftStr(vWaitImage,Length(vWaitImage)-1)]);


  ExecQuery('update CUSTOMER '
