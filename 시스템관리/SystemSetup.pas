procedure TSystemSetupForm.TabletLogSearchButtonClick(Sender: TObject);
var vRestClient   :TRestClient;
    vRestRequest  :TRestRequest;
    vRESTResponse :TRESTResponse;
    vJSONObject : TJSONObject;
    vLogObject : TJSONObject;
    vJsonArray: TJSONArray;
    vJsonValue    :TJSONValue;
    vIndex :Integer;
    vToken, vURL, vData :String;
    vGUID : TGUID;
begin
  inherited;
  if LetsOrderToken = '' then
    LetsOrderToken := LetsOrderAuth(HeadStoreCode);
  if LetsOrderToken = '' then Exit;
  vToken := 'Bearer '+Replace(LetsOrderToken,'"','');
  vURL := GetLetsOrderURL(HeadStoreCode);
  if TableLogCheckBox.Checked then
    vURL := Format('%s/s2s/groups/%s/stores/%s/logs',[vURL,HeadStoreCode,LowerCase(StoreCode)])
  else
    vURL := Format('%s/s2s/groups/%s/stores/%s/logs?created-at=%s',[vURL,HeadStoreCode,LowerCase(StoreCode),DtoS(LogDateEdit.Date)]);

  TabletLogTableView.DataController.RecordCount := 0;
  try
    vRestClient                := TRestClient.Create(nil);
    vRestRequest               := TRestRequest.Create(nil);
    vRESTResponse              := TRESTResponse.Create(vRestRequest);
    vRestRequest.Response      := vRESTResponse;
    vRestClient.BaseURL        := vURL;
    vRESTClient.Accept := 'application/json, text/plain; q=0.9, text/html;q=0.8,';
    vRESTClient.AcceptCharset := 'UTF-8, *;q=0.8';
    vRESTClient.AcceptEncoding := 'UTF-8';
    vRestRequest.Client        := vRestClient;
    vRestRequest.Method        := TRESTRequestMethod.rmGET;
    CoCreateGuid(vGUID);
    vRestRequest.Params.AddHeader('X-Message-Id',  GUIDToString(vGUID));
    vRestRequest.Params.AddHeader('Authorization', vToken);
    vRestRequest.URLAlreadyEncoded := true;

    try
      vRestRequest.Execute;
    except
      Exit;
    end;

    if vRestRequest.Response.StatusCode <> 200 then
    begin
      Exit;
    end;

    vData := vRESTResponse.Content;
    vJSONObject := TJSONObject.ParseJSONValue( vData ) as TJSONObject;
    vLogObject := vJSONObject.GetValue<TJSONObject>('response');

    TabletLogTableView.DataController.BeginUpdate;
    if vLogObject.TryGetValue<TJSONArray>('logs', vJsonArray) then
    begin
      for vIndex := 0 to vJsonArray.Size-1 do
      begin
        vJsonValue := vJsonArray.Get(vIndex);
        TabletLogTableView.DataController.AppendRecord;
        TabletLogTableView.DataController.Values[TabletLogTableView.DataController.RecordCount-1, 0] := vJsonValue.GetValue<String>('created_at');
        TabletLogTableView.DataController.Values[TabletLogTableView.DataController.RecordCount-1, 1] := vJsonValue.GetValue<Integer>('table_no');
        TabletLogTableView.DataController.Values[TabletLogTableView.DataController.RecordCount-1, 2] := vJsonValue.GetValue<String>('action_name');
        TabletLogTableView.DataController.Values[TabletLogTableView.DataController.RecordCount-1, 3] := vJsonValue.GetValue<String>('log_text');
        TabletLogTableView.DataController.Values[TabletLogTableView.DataController.RecordCount-1, 4] := vJsonValue.GetValue<String>('version');
      end;
    end;
    TabletLogTableView.DataController.EndUpdate;
  finally
    vRestClient.Disconnect;
    FreeAndNil(vRESTResponse);
    FreeAndNil(vRESTRequest);
    FreeAndNil(vRESTClient);
  end;
end;

