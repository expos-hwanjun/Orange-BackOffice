procedure TSystemSetupForm.FormKeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
begin
  //KDS 일때
  if KDSPage.Showing then
  begin
    if Shift = [ssCtrl, ssShift] then
    begin
      if SelectedLabel = nil then Exit;
      case Key of
        VK_LEFT  : (SelectedLabel as TcxLabel).Left := (SelectedLabel as TcxLabel).Left - 5;
        VK_RIGHT : (SelectedLabel as TcxLabel).Left := (SelectedLabel as TcxLabel).Left + 5;
        VK_UP    : (SelectedLabel as TcxLabel).Top  := (SelectedLabel as TcxLabel).Top  - 5;
        VK_DOWN  : (SelectedLabel as TcxLabel).Top  := (SelectedLabel as TcxLabel).Top  + 5;
      end;

      try
        isLoading := true;
        DesignLocationTopEdit.Value  := (SelectedLabel as TcxLabel).Top;
        DesignLocationLeftEdit.Value := (SelectedLabel as TcxLabel).Left;
      finally
        isLoading := false;
      end;

      Key := 0;
      PositionNodes(TControl(SelectedLabel));
    end
    else if Shift = [ssCtrl] then
    begin
      if SelectedLabel = nil then Exit;
      case Key of
        VK_LEFT  : (SelectedLabel as TcxLabel).Left := (SelectedLabel as TcxLabel).Left - 1;
        VK_RIGHT : (SelectedLabel as TcxLabel).Left := (SelectedLabel as TcxLabel).Left + 1;
        VK_UP    : (SelectedLabel as TcxLabel).Top  := (SelectedLabel as TcxLabel).Top  - 1;
        VK_DOWN  : (SelectedLabel as TcxLabel).Top  := (SelectedLabel as TcxLabel).Top  + 1;
      end;
      try
        isLoading := true;
        DesignLocationTopEdit.Value  := (SelectedLabel as TcxLabel).Top;
        DesignLocationLeftEdit.Value := (SelectedLabel as TcxLabel).Left;
      finally
        isLoading := false;
      end;

      PositionNodes(TControl(SelectedLabel));
      Key := 0;
    end
    else if Shift = [ssShift] then
    begin
      case Key of
        VK_LEFT  : if (SelectedLabel as TcxLabel).Width > 10 then (SelectedLabel as TcxLabel).Width  := (SelectedLabel as TcxLabel).Width - 1;
        VK_RIGHT : (SelectedLabel as TcxLabel).Width  := (SelectedLabel as TcxLabel).Width + 1;
        VK_UP    : if (SelectedLabel as TcxLabel).Height > 10 then (SelectedLabel as TcxLabel).Height := (SelectedLabel as TcxLabel).Height  - 1;
        VK_DOWN  : (SelectedLabel as TcxLabel).Height := (SelectedLabel as TcxLabel).Height  + 1;
      end;

    end
    else
    if Key = VK_ESCAPE then
    begin
      if SearchPanel.Visible then
        SearchPanel.Visible := false;
      SetNodesVisible(false);
    end;
  end;

  inherited;
end;

procedure TSystemSetupForm.FormResize(Sender: TObject);
begin
  inherited;
  SearchPanel.Height := Pager.Height - 30;
  SearchPanel.Top  := (Pager.Height - SearchPanel.Height) div 2 + Pager.Top;
  SearchPanel.Left := (Pager.Width  - SearchPanel.Width ) div 2 + Pager.Left;
end;

procedure TSystemSetupForm.FormShow(Sender: TObject);
begin
  inherited;
  Pager.Enabled := false;
  Pager.Enabled := DoSearch;
end;

function TSystemSetupForm.CopyDataFaste(aTableName: String): Boolean;
  function GetColum(aTableName:String): String;
  var vCol :Integer;
  begin
    Result := '';
    for vCol := 0 to Query.FieldCount-1 do
      Result := Result + Format('%s,',[Query.Fields[vCol].FieldName]);

    Result := 'insert into '+aTableName+' ('+LeftStr(Result,Length(Result)-1)+') values ';
  end;
var vSQL, vInsertSQL, vTemp, vData :String;
    vCount, vCol :Integer;
begin
  Application.ProcessMessages;

  try
    vInsertSQL := GetColum(aTableName);
    vCount := 0;
    while not Query.Eof do
    begin
      vSQL   := '';
      for vCol := 0 to Query.FieldCount-1 do
      begin
        case Query.Fields[vCol].DataType of
          Data.DB.ftSmallint,
          Data.DB.ftInteger,
          Data.DB.ftWord,
          Data.DB.ftShortint   :
          begin
            if Query.Fields[vCol].Value = null then
              vSQL := vSQL + 'null,'
            else
              vSQL := vSQL + Format('%d,',[Query.Fields[vCol].AsInteger]);
          end;
          Data.DB.ftFloat,
          Data.DB.ftCurrency,
          Data.DB.ftExtended   :
          begin
            if Query.Fields[vCol].Value = null then
              vSQL := vSQL + 'null,'
            else
              vSQL := vSQL + Format('%s,',[FloatToStr(Query.Fields[vCol].AsCurrency)]);
          end;
          Data.DB.ftDate,
          Data.DB.ftTime,
          Data.DB.ftDateTime    :
          begin
            if FormatDateTime('yyyymmdd',Query.Fields[vCol].AsDateTime) < '20000101' then
              vSQL := vSQL + 'null,'
            else
              vSQL := vSQL + Format('Cast(''%s'' as DateTime),',[FormatDateTime('yyyy-mm-dd hh:nn:ss',Query.Fields[vCol].AsDateTime)]);
          end;
          Data.DB.ftBlob : vSQL := vSQL + Format('''%s'',',['']);
          else
          begin
            if Query.Fields[vCol].Value = null then
            begin
              vSQL := vSQL + 'null,';//Format('''%s'',',[vTemp]);
            end
            else
            begin
              vTemp := Replace(Query.Fields[vCol].AsString,';','');
              vTemp := Replace(vTemp,'''','');

              vSQL := vSQL + Format('''%s'',',[vTemp]);
            end;
          end;
        end;
      end;
      vSQL := '('+LeftStr(vSQL, Length(vSQL)-1) + '),';
      vData := vData + vSQL;
      Inc(vCount);
      if vCount = 1000 then
      begin
        vSQL := vInsertSQL + LeftStr(vData, Length(vData)-1) + ';';
        if not ExecQuery(vSQL,[],true) then
        begin
          MsgBox('다시 요청합니다.');
          ExecQuery(vSQL,[],true);
        end;
        vData  := '';
        vCount := 0;
      end;
      Query.Next;
    end;
  finally
  end;

  if vData <> '' then
  begin
    vSQL := vInsertSQL + LeftStr(vData, Length(vData)-1) + ';';
    if not ExecQuery(vSQL,[],true) then
    begin
      MsgBox('다시 요청합니다.');
      ExecQuery(vSQL,[],true);
    end;
  end;
  Query.Close;
end;

