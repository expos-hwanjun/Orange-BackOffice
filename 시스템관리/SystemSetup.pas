procedure TSystemSetupForm.CopyStoreCodeEditPropertiesButtonClick(
  Sender: TObject; AButtonIndex: Integer);
var vStoreList :TStringList;
    vUserLevel :String;
begin
  inherited;
  if Length(CopyStoreCodeEdit.Text) <> 8 then
  begin
    MsgBox('고객번호를 정확히 입력하세요');
    CopyStoreCodeEdit.SetFocus;
    Exit;
  end;

  if LeftStr(CopyStoreCodeEdit.Text,2) <> 'TT' then
    with TProxyCheckForm.Create(self) do
      try
        if ShowModal <> mrOK then
          Exit;
        vUserLevel := ChooseUserLevel;
      finally
        Free;
      end;

  try
    vStoreList := TStringList.Create;
    vStoreList.Text := StoreList.Text;
    StoreList.Clear;
    if vUserLevel = 'P'  then
      DM.OpenQuery('select CD_CUSTOMER, NM_CUSTOMER, CD_COMPANY'
                  +'  from CUSTOMER '
                  +' where CD_PARTNER = (select CD_PARTNER '
                  +'                       from CUSTOMER '
                  +'                      where CD_COMPANY  =:P0 '
                  +'                        and CD_CUSTOMER =:P1) '
                  +'  and DS_STATUS  = ''0'' '
                  +'  and DS_CUSTOMER = ''O'' '
                  +'  and (CD_CUSTOMER =:P2 or NM_CUSTOMER like ConCat(''%'',:P2,''%''))',
                  [HeadStoreCode,
                   StoreCode,
                   CopyStoreCodeEdit.Text], false, RestBaseURL)
    else
      DM.OpenQuery('select CD_CUSTOMER, NM_CUSTOMER, CD_COMPANY'
                  +'  from CUSTOMER '
                  +' where DS_STATUS  = ''0'' '
                  +'   and DS_CUSTOMER = ''O'' '
                  +'   and (CD_CUSTOMER =:P0 or NM_CUSTOMER like ConCat(''%'',:P0,''%''))',
                  [CopyStoreCodeEdit.Text],false,RestBaseURL);

    while not DM.Query.Eof do
    begin
      StoreList.Add(DM.Query.Fields[0].AsString + splitColumn + DM.Query.Fields[1].AsString + splitColumn + DM.Query.Fields[2].AsString);
      DM.Query.Next;
    end;
    DM.Query.Close;

    with TStoreSelectForm.Create(Self) do
      try
        isStoreChange := false;
        if ShowModal = mrOK then
        begin
          CopyStoreCodeEdit.Text     := SelectStoreCode;
          CopyStoreCodeEdit.Hint     := SelectHeadCode;
          CopyStoreNameLabel.Caption := SelectStoreName;
          CopyOkButton.Enabled       := true;
          SourceHead                 := SelectHeadCode;
          SourceStore                := SelectStoreCode;
        end;
      finally
        Free;
      end;
  finally
   DM.Query.Close;
   StoreList.Text := vStoreList.Text;
  end;

end;

