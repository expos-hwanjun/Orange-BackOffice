function TSystemSetupForm.FindControl(Sender: TObject; FocusTab: Boolean):Boolean;
begin
  if (Sender as TControl).Parent = nil then
  begin
    if FocusTab then
      SearchPanel.Visible := false;
    Result := true;
    Exit;
  end
  else if Sender is TcxTabSheet then
  begin
    if ((Sender as TcxTabSheet).Parent <> nil) and (((Sender as TcxTabSheet).Parent) is TcxPageControl) then
    begin
      if not (Sender as TcxTabSheet).TabVisible then
      begin
        Result := false;
        Exit;
      end;
      if FocusTab then
        (((Sender as TcxTabSheet).Parent) as TcxPageControl).Properties.ActivePage := (Sender as TcxTabSheet);
    end;
  end
  else if Sender is TAdvOfficePage then
  begin
    if ((Sender as TAdvOfficePage).Parent <> nil) and (((Sender as TAdvOfficePage).Parent) is TAdvOfficePager) then
    begin
      if not (Sender as TAdvOfficePage).TabVisible then
      begin
        Result := false;
        Exit;
      end;
      if FocusTab then
        (((Sender as TAdvOfficePage).Parent) as TAdvOfficePager).ActivePageIndex := (Sender as TAdvOfficePage).PageIndex;
    end;
  end
  else if Sender is TAdvScrollBox then
  begin
    if ((Sender as TAdvScrollBox).Parent <> nil) and (((Sender as TAdvScrollBox).Parent) is TAdvScrollBox) then
    begin
      if not (Sender as TAdvScrollBox).Visible then
      begin
        Result := false;
        Exit;
      end;
      if FocusTab then
        Result := true;
    end;
  end;

  Result := FindControl((Sender as TControl).Parent, FocusTab);
end;

