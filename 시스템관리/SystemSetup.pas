    vJSONObject.AddPair('image_url', TJSONString.Create(vURL));

    vJSONArray   := TJSONArray.Create;
    for vIndex := 0 to StandbyImageGridTableView.DataController.RecordCount-1 do
    begin
      vJSONDataObject := TJSONObject.Create;
      vJSONDataObject.AddPair('image_file',  TJSONString.Create(StandbyImageGridTableView.DataController.Values[vIndex, StandbyImageGridTableViewFileName.Index]));
      vJSONArray.Add(vJSONDataObject)
    end;

    vJSONObject.AddPair('image',vJSONArray);
    StandbyImage := vJSONObject.ToJSON;
  end
  else
    StandbyImage := vJSONObject.ToJSON;
  ExecQuery('update MS_STORE_ETC '
           +'   set STANDBY_IMAGE =:P2 '
           +' where CD_HEAD  =:P0 '
           +'   and CD_STORE =:P1;'
           +'update MS_STORE '
           +'   set DT_CHANGE = Now() '
           +' where CD_HEAD  =:P0 '
           +'   and CD_STORE =:P1;',
           [HeadStoreCode,
            StoreCode,
            StandbyImage],true, RestDBURL);

//  if aClearCache then
//    LetsOrderImageInvalidate;
end;



