procedure TSystemSetupForm.SelectControl(aControl: TWincontrol);
begin
  if aControl = nil then
  begin
    SelectedLabel                   := nil;
    SelectTag := 0;
    DesignLocationTopEdit.Enabled   := false;
    DesignLocationLeftEdit.Enabled  := false;
    DesignFontEdit.Enabled          := false;
    DesignFormatEdit.Enabled        := false;
    DesignAlignmentComboBox.Enabled := false;
    DesignDeleteButton.Enabled      := false;
    DesignFontEdit.Clear;
    DesignFormatEdit.Clear;
    DesignAlignmentComboBox.ItemIndex := 0;
    SetButtomGroupIndex(0);

    if inReposition then
    begin
      Screen.Cursor := crDefault;
      ReleaseCapture;
      inReposition := False;
    end;
  end
  else
  begin
    SetButtomGroupIndex(1);
    DesignLocationTopEdit.Enabled   := true;
    DesignLocationLeftEdit.Enabled  := true;
    DesignFontEdit.Enabled          := true;
    DesignFormatEdit.Enabled        := true;
    DesignAlignmentComboBox.Enabled := true;
    DesignDeleteButton.Enabled      := true;

    DesignFontEdit.Text   := (aControl as TcxLabel).Style.Font.Name;
    DesignFormatEdit.Text := (aControl as TcxLabel).Hint;

    if (aControl as TcxLabel).Properties.Alignment.Horz = taLeftJustify then
      DesignAlignmentComboBox.ItemIndex := 0
    else if (aControl as TcxLabel).Properties.Alignment.Horz = taRightJustify then
      DesignAlignmentComboBox.ItemIndex := 1
    else if (aControl as TcxLabel).Properties.Alignment.Horz = taCenter then
      DesignAlignmentComboBox.ItemIndex := 2;

    SelectButtonDown((aControl as TcxLabel).Tag);
  end;
end;

procedure TSystemSetupForm.SetButtomGroupIndex(aIndex:Integer);
var vIndex :Integer;
begin
  for vIndex := 0 to ComponentCount-1 do
  begin
    if (Components[vIndex] is TcxButton) and
       ((Components[vIndex] as TcxButton).Parent = DesignGroupBox) then
    begin
      (Components[vIndex] as TcxButton).SpeedButtonOptions.GroupIndex := aIndex;
    end;
  end;
end;

procedure TSystemSetupForm.SetChanged(aChanged: Boolean);
begin
  inherited;
  ButtonToolBarSaveButton.Enabled := aChanged;
end;

procedure TSystemSetupForm.SelectButtonDown(aTag :Integer);
var vIndex :Integer;
begin
  for vIndex := 0 to ComponentCount-1 do
  begin
    if (Components[vIndex] is TcxButton) and
       ((Components[vIndex] as TcxButton).Parent = DesignGroupBox) and
       ((Components[vIndex] as TcxButton).Tag = aTag) then
    begin
      (Components[vIndex] as TcxButton).SpeedButtonOptions.Down := true;
      Break;
    end;
  end;
end;

end.
