procedure TSystemSetupForm.DesignTemplateComboBoxPropertiesChange(
  Sender: TObject);
  procedure ClearComponent;
  var vIndex :Integer;
  label go;
  begin
    go:
    for vIndex := 0 to ComponentCount-1 do
    begin
      if (Components[vIndex] is TcxLabel) and ( ((Components[vIndex] as TcxLabel).Parent = DesignTopPanel) or ((Components[vIndex] as TcxLabel).Parent = DesignCenterPanel) or ((Components[vIndex] as TcxLabel).Parent = DesignBottomPanel) ) then  //KDSDesignPanel
      begin
        if ((Components[vIndex] as TcxLabel).Tag <> 4) and ((Components[vIndex] as TcxLabel).Tag <> 9) and ((Components[vIndex] as TcxLabel).Tag <> 12)  then
        begin
          Components[vIndex].Free;
          Goto go;
        end;
      end;
    end;
  end;
var vDesignLabel :TcxLabel;
begin
  inherited;
  ClearComponent;
  Design4Label.Left := 10;
  Design4Label.Top  := 20;
  Design4Label.Style.Font.Size := 14;
  Design4Label.Style.Font.Name := '굴림';
  Design9Label.Left := 150;
  Design9Label.Top  := 20;
  Design9Label.Style.Font.Size := 14;
  Design9Label.Style.Font.Name := '굴림';

  Design12Label.Top  := 4;
  Design12Label.Left := DesignBottomPanel.Width div 2  - (Design12Label.Width div 2);


  SetNodesVisible(False);
  SelectedLabel := nil;
  SelectControl(nil);

  DesignGroupBox.Enabled     := true;
  KDSColorGroupBox.Enabled   := true;
  DesignRowSizeEdit.Enabled  := true;
  DesignColSizeEdit.Enabled  := true;
  KDSAllKitchenCopyButton.Enabled := true;
  try
    OpenQuery('select * '
             +'  from MS_KDS_H '
             +' where CD_HEAD     =:P0 '
             +'   and CD_STORE    =:P1 '
             +'   and CD_TEMPLATE =:P2 ',
             [HeadStoreCode,
              StoreCode,
              GetStrPointerData(DesignTemplateComboBox)]);
    if not Query.Eof then
    begin
      DesignRowSizeEdit.Value     := Query.FieldByName('ROW_COUNT').AsInteger;
      DesignColSizeEdit.Value     := Query.FieldByName('COL_COUNT').AsInteger;
      EditPropertiesChange(DesignRowSizeEdit);
      EditPropertiesChange(DesignColSizeEdit);


      WaitColorPanel.Color    := HexToTColor(Query.FieldByName('WAIT_COLOR').AsString);
      CookingColorPanel.Color := HexToTColor(Query.FieldByName('COOKING_COLOR').AsString);
      FinishColorPanel.Color  := HexToTColor(Query.FieldByName('FINISH_COLOR').AsString);

      DesignTopHeightEdit.Value      := Query.FieldByName('TOP_HEIGHT').AsInteger;
      DesignBottomHeightEdit.Value   := Query.FieldByName('BOTTOM_HEIGHT').AsInteger;
    end
    else
    begin
      DesignRowSizeEdit.Value      := 3;
      DesignColSizeEdit.Value      := 3;
      EditPropertiesChange(DesignRowSizeEdit);
      EditPropertiesChange(DesignColSizeEdit);

      WaitColorPanel.Color    := HexToTColor('000000');
      CookingColorPanel.Color := HexToTColor('000000');
      FinishColorPanel.Color  := HexToTColor('000000');

      DesignTopHeightEdit.Value      := 40;
      DesignBottomHeightEdit.Value   := 40;
      Design12Label.Top  := 1;
      Design12Label.Left := DesignBottomPanel.Width div 2  - (Design12Label.Width div 2);
    end;
  finally
    FinishQuery;
  end;

  try
    OpenQuery('select * '
             +'  from MS_KDS_D '
             +' where CD_HEAD     =:P0 '
             +'   and CD_STORE    =:P1 '
             +'   and CD_TEMPLATE =:P2 ',
             [HeadStoreCode,
              StoreCode,
              GetStrPointerData(DesignTemplateComboBox)]);
    while not Query.Eof do
    begin
      if Query.FieldByName('CD_OBJECT').AsInteger = 4 then
        vDesignLabel := Design4Label
      else if Query.FieldByName('CD_OBJECT').AsInteger = 9 then
        vDesignLabel := Design9Label
      else if Query.FieldByName('CD_OBJECT').AsInteger = 12 then
        vDesignLabel := Design12Label
      else
        vDesignLabel := TcxLabel.Create(Self);
      with vDesignLabel do
      begin
        vDesignLabel.Top  := Query.FieldByName('OBJECT_TOP').AsInteger;
        if vDesignLabel.Top < 0 then vDesignLabel.Top := 0;
        vDesignLabel.Left := Query.FieldByName('OBJECT_LEFT').AsInteger;
        if vDesignLabel.Left < 0 then vDesignLabel.Left := 0;
        if Query.FieldByName('OBJECT_PARENT').AsString = 'T' then
          Parent := DesignTopPanel
        else if Query.FieldByName('OBJECT_PARENT').AsString = 'C' then
          Parent := DesignCenterPanel
        else if Query.FieldByName('OBJECT_PARENT').AsString = 'B' then
          Parent := DesignBottomPanel;

        Hint := Query.FieldByName('OBJECT_FORMAT').AsString;
        Style.Font.Name  := Query.FieldByName('FONT_NAME').AsString;
        Style.Font.Size  := Query.FieldByName('FONT_SIZE').AsInteger;
        Style.Font.Color := HexToTColor(Query.FieldByName('FONT_COLOR').AsString);
       // 글꼴 스타일(굵게, 기울임 등)
        Style.Font.Style    := [];
        if (Query.FieldByName('FONT_STYLE').AsInteger and $01) = $01 then
          Style.Font.Style  := Style.Font.Style + [fsBold];
        if (Query.FieldByName('FONT_STYLE').AsInteger and $02) = $02 then
          Style.Font.Style  := Style.Font.Style + [fsItalic];
        if (Query.FieldByName('FONT_STYLE').AsInteger and $04) = $04 then
          Style.Font.Style  := Style.Font.Style + [fsUnderline];
        if (Query.FieldByName('FONT_STYLE').AsInteger and $08) = $08 then
          Style.Font.Style  := Style.Font.Style + [fsStrikeOut];

        if Query.FieldByName('FONT_ALIGN').AsString = 'L' then
          Properties.Alignment.Horz := taLeftJustify
        else if Query.FieldByName('FONT_ALIGN').AsString = 'R' then
          Properties.Alignment.Horz := taRightJustify
        else if Query.FieldByName('FONT_ALIGN').AsString = 'C' then
          Properties.Alignment.Horz := taCenter;

        Tag := Query.FieldByName('CD_OBJECT').AsInteger;

        if Query.FieldByName('CD_OBJECT').AsInteger = 12 then
        begin
          Height := Query.FieldByName('OBJECT_HEIGHT').AsInteger;
          Width  := Query.FieldByName('OBJECT_WIDTH').AsInteger;
        end;

        Caption := ObjectName[Tag];
        Name    := Format('Design%dLabel',[Tag]);
        OnMouseDown       := ControlMouseDown;
        OnMouseMove       := ControlMouseMove;
        OnMouseUp         := ControlMouseUp;
        Onclick           := DesignLabelClick;
      end;
      Query.Next;
    end;
  finally
    FinishQuery;
  end;
end;

procedure TSystemSetupForm.DesignTopPanelClick(Sender: TObject);
  function GetFindComponent(aTag :Integer):Boolean;
  var vIndex :Integer;
  begin
    Result := false;
    for vIndex := 0 to ComponentCount-1 do
    begin
      if (Components[vIndex] is TcxLabel) and
         ( ((Components[vIndex] as TcxLabel).Parent = DesignTopPanel) or ((Components[vIndex] as TcxLabel).Parent = DesignCenterPanel) or ((Components[vIndex] as TcxLabel).Parent = DesignBottomPanel) ) and
         ((Components[vIndex] as TcxLabel).Tag = aTag) then
      begin
        Result :=true;
        Break;
      end;
    end;
  end;
var vDesignLabel :TcxLabel;
    vPos: TPoint;
begin
  inherited;
  if (SelectTag = 0) or GetFindComponent(SelectTag) then
  begin
    SetNodesVisible(False);
    SelectControl(nil);
    ClipCursor(nil);
    Exit;
  end;

  if (Sender <> DesignCenterPanel) and (SelectTag = 11) then
  begin
    MsgBox('메뉴주문시간은 가운데 위치만 가능합니다');
    Exit;
  end;


  if (Sender = DesignCenterPanel) and not (SelectTag in [4,9,11]) then
  begin
    MsgBox('메뉴,수량,메뉴주문시간은 가운데 위치만 가능합니다');
    Exit;
  end;

  vDesignLabel := TcxLabel.Create(Self);
  try
    isLoading := true;
    with vDesignLabel do
    begin
      vPos := GetCursorPosForControl((Sender as TPanel));
      Top    := Integer(vPos.Y)-7;
      Left   := Integer(vPos.X);
      Parent := (Sender as TPanel);
      Tag    := SelectTag;
      Style.Font.Size   := 14;
      Caption := ObjectName[SelectTag];
      Name    := Format('Design%dLabel',[Tag]);
      OnMouseDown       := ControlMouseDown;
      OnMouseMove       := ControlMouseMove;
      OnMouseUp         := ControlMouseUp;
      Onclick           := DesignLabelClick;

      DesignLocationTopEdit.Value  := Top;
      DesignLocationLeftEdit.Value := Left;
    end;
  finally
    isLoading := false;
  end;

  SetNodesVisible(True);
  SelectedLabel := vDesignLabel;
  PositionNodes(TControl(vDesignLabel));
  SelectControl(SelectedLabel);
  isChanged := true;
end;

procedure TSystemSetupForm.NodeMouseDown(Sender: TObject; Button: TMouseButton;
  Shift: TShiftState; X, Y: Integer);
begin
  if (Sender is TControl) then
  begin
    NodePositioning := True;
    GetCursorPos(oldPos);
  end;
