procedure TSystemSetupForm.LetsOrderOptionPager1Show(Sender: TObject);
var
  vStream    : TStream;
  vPNG       : TPNGImage;
begin
  inherited;
  OpenQuery('select LOGO, '
           +'       COLOR '
           +'  from LETSORDER_QR '
           +' where CD_HEAD  =:P0 '
           +'   and CD_STORE =:P1 ',
           [HeadStoreCode,
            StoreCode],false,RestBaseURL);
  LogoImage.Picture := nil;
  if not Query.Eof then
  begin
    if (Query.FieldByName('LOGO').AsString <> '') then
    begin
      vStream := Query.CreateBLOBStream(Query.FieldByName('LOGO'), bmRead);
      vPNG    := TPNGImage.Create;
      try
        vPNG.LoadFromStream(vStream);
        LogoImage.Picture.Assign(vPNG);
      finally
        vStream.Free;
        vPNG.Free;
      end;
    end;
    if Query.FieldByName('COLOR').AsString <> '' then
    begin
      LetsOrderAppColorPanel.Color   := StringToColor(Query.FieldByName('COLOR').AsString);
      LetsOrderAppColorPanel.Caption := '';
    end;
  end;

  Query.Close;
end;

