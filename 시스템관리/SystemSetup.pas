procedure TSystemSetupForm.SmartPadPageShow(Sender: TObject);
var vIndex :Integer;
    vTemp  :String;
    vJsonObject : TJSONObject;
    vJsonArray  : TJSONArray;
    vJsonValue  : TJSONValue;
begin
  inherited;

  OpenQuery('select SMARTPAD_CHANGETIME, '
           +'       SMARTPAD_WAITIMAGE '
           +'  from CUSTOMER '
           +' where CD_COMPANY  =:P0 '
           +'   and CD_CUSTOMER =:P1 ',
           [HeadStoreCode,
            StoreCode],false, RestBaseURL);

  SmartPadView.DataController.RecordCount := 0;
  if not Query.Eof then
  begin
    vTemp := Query.FieldByName('SMARTPAD_WAITIMAGE').AsString;
    if vTemp <> '' then
    begin
      vJsonObject := TJSONObject.ParseJSONValue( vTemp ) as TJSONObject;
      vJsonArray  := TJsonArray( vJsonObject.Get('FILE').JsonValue );
      for vIndex := 0 to vJsonArray.Size-1 do
      begin
        vJsonValue := vJsonArray.Get(vIndex);
        SmartPadView.DataController.AppendRecord;
        SmartPadView.DataController.Values[SmartPadView.DataController.RecordCount-1, 0] := IntToStr(vIndex+1);
        SmartPadView.DataController.Values[SmartPadView.DataController.RecordCount-1, 1] := vJsonValue.GetValue<String>;
      end;
    end;
    WaitImageChangeTimeSpinEdit.Value := Query.FieldByName('SMARTPAD_CHANGETIME').AsString;
  end;
  Query.Close;
end;

