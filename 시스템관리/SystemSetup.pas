//==============================================================================
// 폼
//------------------------------------------------------------------------------
// 폼을 보여줄 때
procedure TSystemSetupForm.FormCreate(Sender: TObject);
var
  vCode  :PStrPointer;
  vPopMenuItem: TMenuItem;
  vIndex :Integer;
begin
  Pager.ActivePageIndex := 0;
  inherited;
  isLoading      := true;
  LetsOrderToken := '';
  Option379ComboBox.Properties.Items.Clear;
  New(vCode);
  vCode^.Data := '2';
  Option379ComboBox.Properties.Items.AddObject('가상단말기(VCat)', TObject(vCode));
  New(vCode);
  vCode^.Data := '1';
  Option379ComboBox.Properties.Items.AddObject('단말기 연동', TObject(vCode));


  //메인포스
  try
    OpenQuery('select NM_CODE1 '
             +'  from MS_CODE '
             +' where CD_HEAD  =:P0 '
             +'   and CD_STORE =:P1 '
             +'   and CD_KIND  =''01'' '
             +'   and DS_STATUS = 0 '
             +' order by CD_CODE ',
             [HeadStoreCode,
              StoreCode]);
    MainPosComboBox.Properties.Items.Clear;
    while not Query.Eof do
    begin
      MainPosComboBox.Properties.Items.Add(Query.Fields[0].AsString);
      Query.Next;
    end;
  finally
    FinishQuery;
  end;

  //영수증기본할인
  try
    OpenQuery('select CD_CODE, '
             +'       NM_CODE1 '
             +'  from MS_CODE '
             +' where CD_HEAD  =:P0 '
             +'   and CD_STORE =:P1 '
             +'   and CD_KIND  =''07'' '
             +'   and DS_STATUS = 0 '
             +' order by CD_CODE ',
             [HeadStoreCode,
              StoreCode]);
    ReceiptDefaultDcComboBox.Properties.Items.Clear;
    New(vCode);
    vCode^.Data := EmptyStr;
    ReceiptDefaultDcComboBox.Properties.Items.AddObject('사용안함', TObject(vCode));
    while not Query.Eof do
    begin
