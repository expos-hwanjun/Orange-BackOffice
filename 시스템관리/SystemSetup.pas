procedure TSystemSetupForm.LogoLoadButtonClick(Sender: TObject);
var
  vWidth, vHeight: Integer;
  vBMP: TBitmap;
  vPNG: TPNGImage;
  vStream :TMemoryStream;
begin
  inherited;
  if PictureLoadDialog.Execute then
  begin
    LogoImage.Picture.LoadFromFile(PictureLoadDialog.FileName);

    // 이미지를 JPG 형태의 작은 사진으로 수정해 저장한다
    if LogoImage.Picture.Width > LogoImage.Height then
    begin
      vWidth  := LogoImage.Width;
      vHeight := Trunc(LogoImage.Picture.Height * (vWidth / LogoImage.Picture.Width));
    end
    else
    begin
      vHeight := LogoImage.Height;
      vWidth  := Trunc(LogoImage.Picture.Width * (vHeight / LogoImage.Picture.Height));
    end;
    vBMP    := TBitmap.Create;
    vPNG    := TPNGImage.Create;
    vStream := TMemoryStream.Create;
    try
      vBMP.Width  := vWidth;
      vBMP.Height := vHeight;
      vBMP.Canvas.StretchDraw(vBMP.Canvas.ClipRect, LogoImage.Picture.Graphic);
      vPNG.Assign(vBMP);
      LogoImage.Picture.Assign(vPNG);
      vPNG.SaveToStream(vStream);

      ExecQuery('update LETSORDER_QR '
               +'   set LOGO       = :P2 '
               +' where CD_HEAD    = :P0 '
               +'   and CD_STORE   = :P1;',
               [HeadStoreCode,
                StoreCode,
                EncodeBase64(vStream.Memory, vStream.Size)],true, RestBaseURL);
    finally
      vStream.Free;
      vBMP.Free;
      vPNG.Free;
    end;
  end;
end;

