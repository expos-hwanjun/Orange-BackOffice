constructor TSystemSetupForm.Create(AOwner: TComponent);
begin
  inherited;
  Nodes := TObjectList.Create(False);
  CreateNodes;
end;

procedure TSystemSetupForm.CreateNodes;
var
  vNode: Integer;
  vPanel: TPanel;
begin
  for vNode := 0 to 7 do
  begin
    vPanel := TPanel.Create(Self);
    Nodes.Add(vPanel);
    with vPanel do
    begin
      BevelOuter := bvNone;
      Color   := clBlack;
      Name    := 'Node' + IntToStr(vNode);
      Width   := 5;
      Height  := 5;
      Parent  := Self;
      Visible := False;

      case vNode of
        0,4: Cursor := crSizeNWSE;
        1,5: Cursor := crSizeNS;
        2,6: Cursor := crSizeNESW;
        3,7: Cursor := crSizeWE;
      end;
      OnMouseDown := NodeMouseDown;
      OnMouseMove := NodeMouseMove;
      OnMouseUp   := NodeMouseUp;
    end;
  end;
end;

procedure TSystemSetupForm.SetNodesVisible(Visible: Boolean);
var
  vIndex: Integer;
begin
  for vIndex := 0 to 7 do
    TControl(Nodes.Items[vIndex]).Visible := Visible;
end;


procedure TSystemSetupForm.SetQR;
var
  vQRCode: TDelphiZXingQRCode;
  vRow, vColumn: Integer;
  vURL :String;
begin
  if isLoading then Exit;

  vQRCode := TDelphiZXingQRCode.Create;
  try
    if QRURL = '' then
    begin
      OpenQuery('select b.LETSORDER_URL_NEW '
               +'  from COMPANY     as a inner join '
               +'       SERVER_LIST as b on b.ID_SERVER = a.ID_SERVER '
               +' where a.CD_COMPANY  =:P0 ',
               [HeadStoreCode],false,RestBaseURL);

      if not Query.Eof and (Pos(':7308', Query.Fields[0].AsString) > 0) then
        QRURL := 'qa'
      else
        QRURL := '';
      Query.Close;
  end;

    vURL := Format('{"HeadStore":"%s","StoreCode":"%s","Server":"%s","Password":"%s","AuthCode":"%s"}',[HeadStoreCode, StoreCode, QRURL, QRPasswordEdit.Text,AuthNoEdit.Text]);
    vQRCode.Data := vURL;

    vQRCode.Encoding := TQRCodeEncoding(0);
    vQRCode.QuietZone := 4;
    QRCodeBitmap.SetSize(vQRCode.Rows, vQRCode.Columns);
    for vRow := 0 to vQRCode.Rows - 1 do
    begin
      for vColumn := 0 to vQRCode.Columns - 1 do
      begin
        if (vQRCode.IsBlack[vRow, vColumn]) then
        begin
          QRCodeBitmap.Canvas.Pixels[vColumn, vRow] := clBlack;
        end else
        begin
          QRCodeBitmap.Canvas.Pixels[vColumn, vRow] := clWhite;
        end;
      end;
    end;
  finally
    vQRCode.Free;
  end;
  PaintBox.Repaint;

  QRStoreLabel.Caption := StoreName;
end;

