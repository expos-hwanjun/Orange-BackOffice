procedure TSystemSetupForm.SmartPadImageAddButtonClick(Sender: TObject);
var Files: TSearchRec;
    vIndex : Integer;
    vHttp: TIdHTTP;
    vParams: TIdMultiPartFormDataStream;
    vResponse: string;
    vURL, vDownURL :String;
    vImage :TImage;
    vUpFileName,
    vFileName:String;
    vWaitImage :String;
begin
  OpenDialog.Filter := 'jpg files(*.jpg)|*.jpg|png files(*.png)|*.png';

  if not OpenDialog.Execute then exit;

  FindFirst(OpenDialog.FileName,faArchive,Files);
  if (RightStr(OpenDialog.FileName,3) = 'png') or (RightStr(OpenDialog.FileName,3) = 'jpg') then
  begin
    if (Files.Size div 1000) > 3000 then
    begin
      MsgBox(Format('최대크기는 최대 3 MB 입니다(%d)', [Files.Size div 1000]));
      Exit;
    end;

    try
      vImage := TImage.Create(self);
      vImage.Picture.LoadFromFile(OpenDialog.FileName);
      if (vImage.Width > 1920) or (vImage.Height > 1080) then
      begin
        MsgBox('최대 이미지 크기는 최대 1920 * 1080 입니다');
        Exit;
      end;
    finally
      vImage.Free;
    end;
  end;


  vFileName   := 'SmpartPadImage'+FormatDateTime('_yymmddhhnnss',now())+  RightStr(Files.Name, 4);
  vUpFileName := Replace(OpenDialog.FileName, Files.Name, vFileName);
  CopyFile(PWideChar(OpenDialog.FileName), PWideChar(vUpFileName), true);

  try
    vHttp   := TIdHTTP.Create;
    vParams := TIdMultiPartFormDataStream.Create;
    vURL    := 'http://39.120.147.83:50280/Orange/Action_FileUp';

    vDownURL := 'https://xn--6j1b831b.kr/FTP/Tablet';

    try
      Screen.Cursor := crArrow;
      vHttp.Request.CustomHeaders.AddValue('COMP_ID',Format('Tablet/%s/%s',[HeadStoreCode,StoreCode]));
      vHttp.Request.CustomHeaders.AddValue('JOB_GBN','U');
      vParams.AddFile('0', vUpFileName);
      vResponse := vHttp.Post(vURL, vParams);
      if vResponse <> 'OK' then
      begin
        Screen.Cursor := crDefault;
        ErrBox('화일전송실패!!!'#13+ vResponse);
        Exit;
      end;
    except
      on E:Exception do
      begin
        Screen.Cursor := crDefault;
        ErrBox(E.Classname + ': '+ E.Message);
      end;
    end;
  finally
    vHttp.Disconnect;
    Screen.Cursor := crDefault;
    vParams.Free;
    vHttp.Free;
  end;

  SmartPadView.DataController.AppendRecord;
  SmartPadView.DataController.Values[SmartPadView.DataController.RecordCount-1, 0] := IntToStr(SmartPadView.DataController.RecordCount);
  SmartPadView.DataController.Values[SmartPadView.DataController.RecordCount-1, 1] := vFileName;
  SmartPadView.DataController.PostEditingData;

  vWaitImage := '';
  for vIndex := 0 to SmartPadView.DataController.RecordCount-1 do
    vWaitImage := vWaitImage + Format('"%s",',[SmartPadView.DataController.Values[vIndex, 1]]);

  vWaitImage := Format('{"url":"%s","head":"%s","store":"%s","FILE":[%s]}',[vDownURL, HeadStoreCode, StoreCode, LeftStr(vWaitImage,Length(vWaitImage)-1)]);

  ExecQuery('update CUSTOMER '
           +'   set SMARTPAD_WAITIMAGE =:P2 '
           +' where CD_COMPANY  =:P0 '
           +'   and CD_CUSTOMER =:P1;',
           [HeadStoreCode,
            StoreCode,
            vWaitImage],true, RestBaseURL);
end;

procedure TSystemSetupForm.SmartPadImageDeleteButtonClick(Sender: TObject);
var vIdHTTP     : TIdHTTP;
    vRequest : TStringStream;
    vResponse :String;
    vFileName :String;
    vWaitImage, vURL, vDownURL :String;
