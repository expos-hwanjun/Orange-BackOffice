      '    13 : TfrxBarCodeView(Sender).BarType := bcCodeEAN13;  '
      '    7  : TfrxBarCodeView(Sender).BarType := bcCodeUPC_E0;  '
      '    12 : TfrxBarCodeView(Sender).BarType := bcCodeUPC_A;  '
      
        '    else TfrxBarCodeView(Sender).BarType := bcCode39;           ' +
        '     '
      '  end;  '
      'end;'
      ''
      'begin'
      ''
      'end.')
